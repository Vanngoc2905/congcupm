@model IEnumerable<vnfood.Models.OrderItem>
@{
    ViewData["Title"] = "Quản lý Cửa hàng - Đơn hàng đến";
    ViewData["ActiveNav"] = "vendor";
}

<div style="max-width: 1000px; margin: 0 auto; padding: 24px 16px;">
    
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px;">
        <div>
            <h1 style="font-size: 28px; font-weight: 800; color: var(--text-dark); margin: 0;">Quản lý Cửa hàng</h1>
            <p style="color: var(--text-medium); margin-top: 4px;">Xem và xử lý các đơn hàng khách hàng đã đặt từ bạn.</p>
        </div>
        <div style="display: flex; gap: 12px;">
            <a href="/Vendor/MyProducts" class="btn-primary-vn" style="background: white; border: 1px solid var(--border); color: var(--text-dark); text-decoration: none;">
                <i class="fa fa-boxes-stacked"></i> Sản phẩm của tôi (@ViewBag.ProductCount)
            </a>
            <a href="/Product/Create" class="btn-primary-vn" style="text-decoration: none;">
                <i class="fa fa-plus"></i> Thêm sản phẩm mới
            </a>
        </div>
    </div>

    <div class="card-vn" style="padding: 0; overflow: hidden;">
        <div style="padding: 20px; border-bottom: 1px solid var(--border); background: #f8fafc;">
            <h3 style="font-size: 16px; font-weight: 700; color: var(--text-dark); margin: 0;">Đơn hàng mới nhất</h3>
        </div>

        @if (!Model.Any())
        {
            <div style="padding: 60px; text-align: center;">
                <div style="font-size: 48px; color: #e2e8f0; margin-bottom: 20px;"><i class="fa fa-receipt"></i></div>
                <h3 style="color: var(--text-medium); margin-bottom: 8px;">Chưa có đơn hàng nào.</h3>
                <p style="color: #94a3b8; font-size: 14px;">Khi khách hàng mua sản phẩm của bạn, thông tin sẽ hiện ở đây.</p>
            </div>
        }
        else
        {
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f1f5f9; text-align: left; border-bottom: 1px solid var(--border);">
                        <th style="padding: 14px 20px; font-size: 12px; color: #64748b; font-weight: 700; text-transform: uppercase;">Mã ĐH / Ngày</th>
                        <th style="padding: 14px 20px; font-size: 12px; color: #64748b; font-weight: 700; text-transform: uppercase;">Khách hàng</th>
                        <th style="padding: 14px 20px; font-size: 12px; color: #64748b; font-weight: 700; text-transform: uppercase;">Sản phẩm / SL</th>
                        <th style="padding: 14px 20px; font-size: 12px; color: #64748b; font-weight: 700; text-transform: uppercase;">Thành tiền</th>
                        <th style="padding: 14px 20px; font-size: 12px; color: #64748b; font-weight: 700; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 14px 20px; font-size: 12px; color: #64748b; font-weight: 700; text-transform: uppercase;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid var(--border); transition: all 0.2s;">
                            <td style="padding: 20px;">
                                <div style="font-weight: 700; color: var(--text-dark); mb-1">#@item.Order.Id</div>
                                <div style="font-size: 12px; color: var(--text-medium);">@item.Order.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td style="padding: 20px;">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <img src="@(item.Order.User.AvatarUrl ?? "/images/default-avatar.png")" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;" />
                                    <div>
                                        <div style="font-weight: 600; color: var(--text-dark); font-size: 14px;">@item.Order.FullName</div>
                                        <div style="font-size: 11px; color: var(--text-medium);">@item.Order.PhoneNumber</div>
                                    </div>
                                </div>
                            </td>
                            <td style="padding: 20px;">
                                <div style="font-weight: 600; color: var(--text-dark);">@item.Product.Name</div>
                                <div style="font-size: 12px; color: var(--text-medium);">Số lượng: <span style="font-weight: 700; color: var(--text-dark);">@item.Quantity</span></div>
                            </td>
                            <td style="padding: 20px;">
                                <div style="font-weight: 800; color: #ef4444;">@((item.UnitPrice * item.Quantity).ToString("N0")) đ</div>
                                <div style="font-size: 11px; color: var(--text-medium);">@item.Order.PaymentMethod</div>
                            </td>
                            <td style="padding: 20px;">
                                <span class="status-badge status-@item.Order.Status.Replace(" ", "-").ToLower()">
                                    @item.Order.Status
                                </span>
                            </td>
                            <td style="padding: 20px;">
                                <form asp-action="UpdateOrderStatus" method="post" style="display: flex; gap: 6px;">
                                    <input type="hidden" name="orderId" value="@item.OrderId" />
                                    <select name="status" class="form-control-vn" style="font-size: 12px; height: 32px; width: 130px; padding: 0 8px;" onchange="this.form.submit()">
                                        <option value="Chờ xác nhận" selected="@(item.Order.Status == "Chờ xác nhận")">Chờ xác nhận</option>
                                        <option value="Đang chuẩn bị" selected="@(item.Order.Status == "Đang chuẩn bị")">Đang chuẩn bị</option>
                                        <option value="Đang giao" selected="@(item.Order.Status == "Đang giao")">Đang giao</option>
                                        <option value="Hoàn thành" selected="@(item.Order.Status == "Hoàn thành")">Hoàn thành</option>
                                        <option value="Đã hủy" selected="@(item.Order.Status == "Đã hủy")">Đã hủy</option>
                                    </select>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>

<style>
    .status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        display: inline-block;
    }
    .status-cho-xác-nhận { background: #fef9c3; color: #854d0e; }
    .status-đang-chuẩn-bị { background: #dcfce7; color: #166534; }
    .status-đang-giao { background: #dbeafe; color: #1e40af; }
    .status-hoàn-thành { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
    .status-đã-hủy { background: #fee2e2; color: #991b1b; }
    
    tbody tr:hover { background: #f8fafc; }
</style>
