@model IEnumerable<vnfood.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm của tôi - Quản lý Cửa hàng";
    ViewData["ActiveNav"] = "vendor";
}

<div style="max-width: 1000px; margin: 0 auto; padding: 24px 16px;">
    
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px;">
        <div>
            <h1 style="font-size: 28px; font-weight: 800; color: var(--text-dark); margin: 0;">Sản phẩm của tôi</h1>
            <p style="color: var(--text-medium); margin-top: 4px;">Danh sách tất cả các sản phẩm bạn đang đăng bán trên Chợ Bếp Việt.</p>
        </div>
        <div style="display: flex; gap: 12px;">
            <a href="/Vendor/Dashboard" class="btn-primary-vn" style="background: white; border: 1px solid var(--border); color: var(--text-dark); text-decoration: none;">
                <i class="fa fa-receipt"></i> Đơn hàng đến
            </a>
            <a href="/Product/Create" class="btn-primary-vn" style="text-decoration: none;">
                <i class="fa fa-plus"></i> Đăng sản phẩm mới
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card-vn" style="padding: 60px; text-align: center;">
            <div style="font-size: 48px; color: #e2e8f0; margin-bottom: 20px;"><i class="fa fa-boxes-stacked"></i></div>
            <h3 style="color: var(--text-medium); margin-bottom: 12px;">Bạn chưa có sản phẩm nào.</h3>
            <a href="/Product/Create" style="color: var(--primary); font-weight: 700; text-decoration: none;">Bắt đầu đăng bán ngay</a>
        </div>
    }
    else
    {
        <div style="display: grid; gap: 16px;">
            @foreach (var item in Model)
            {
                <div class="card-vn" style="padding: 20px; display: grid; grid-template-columns: 80px 1fr 150px 150px 120px; align-items: center; gap: 20px;">
                    <div style="width: 80px; height: 80px; border-radius: 8px; overflow: hidden; background: #f1f5f9;">
                        <img src="@(item.ImageUrl ?? "/images/no-image.png")" style="width: 100%; height: 100%; object-fit: cover;" />
                    </div>
                    
                    <div>
                        <div style="font-size: 12px; color: var(--primary); font-weight: 700; margin-bottom: 4px;">@item.Category.Name</div>
                        <h4 style="margin: 0; font-size: 16px; font-weight: 700; color: var(--text-dark);">@item.Name</h4>
                        <div style="font-size: 12px; color: var(--text-medium); margin-top: 4px;">Ngày tạo: @item.CreatedAt.ToString("dd/MM/yyyy")</div>
                    </div>

                    <div style="text-align: center;">
                        <div style="font-size: 13px; color: var(--text-medium); margin-bottom: 4px;">Giá bán</div>
                        <div style="font-weight: 800; color: #ef4444; font-size: 16px;">@item.Price.ToString("N0") đ</div>
                    </div>

                    <div style="text-align: center;">
                        <div style="font-size: 13px; color: var(--text-medium); margin-bottom: 4px;">Tồn kho</div>
                        <div style="font-weight: 700; color: @(item.StockQuantity < 5 ? "#ef4444" : "var(--text-dark)"); font-size: 16px;">
                            @item.StockQuantity
                        </div>
                    </div>

                    <div style="display: flex; gap: 8px; justify-content: flex-end;">
                        <a href="/Product/Detail/@item.Id" class="btn-icon-vn" style="color:var(--primary);" title="Xem"><i class="fa fa-eye"></i></a>
                        <a href="/Product/Edit/@item.Id" class="btn-icon-vn" style="color:#64748b;" title="Sửa"><i class="fa fa-pen"></i></a>
                        <form asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa sản phẩm này?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-icon-vn" style="color:#ef4444; background: none; border: none; cursor: pointer;"><i class="fa fa-trash"></i></button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }

</div>

<style>
    .btn-icon-vn {
        width: 36px;
        height: 36px;
        background: #f1f5f9;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-icon-vn:hover { background: #e2e8f0; }
</style>
