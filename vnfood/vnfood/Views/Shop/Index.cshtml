@model IEnumerable<vnfood.Models.Product>
@{
    ViewData["Title"] = "Chợ Bếp Việt - Mua sắm dụng cụ & nguyên liệu";
    ViewData["ActiveNav"] = "shop";
    var categories = ViewBag.Categories as List<vnfood.Models.Category>;
    int? selectedId = ViewBag.SelectedCategoryId;
}

<div style="max-width: 1200px; margin: 0 auto; padding: 24px 16px;">
    
    <!-- Top Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <div>
            <h1 style="font-size: 28px; font-weight: 800; color: var(--text-dark); margin: 0;">Chợ Bếp Việt</h1>
            <p style="color: var(--text-medium); margin-top: 4px;">Dụng cụ chuyên nghiệp, nguyên liệu tươi sạch cho gian bếp của bạn.</p>
        </div>
        <a href="/Product/Create" class="btn-primary-vn" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
            <i class="fa fa-plus-circle"></i> Đăng bán sản phẩm
        </a>
    </div>

    <div style="display: grid; grid-template-columns: 240px 1fr; gap: 30px;">
        
        <!-- Sidebar Filter -->
        <aside>
            <div class="card-vn" style="padding: 20px; position: sticky; top: 84px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                    <i class="fa fa-list-ul" style="color: var(--primary);"></i> Danh mục
                </h3>
                <div style="display: grid; gap: 8px;">
                    <a href="/Shop" class="category-link @(selectedId == null ? "active" : "")">
                        Tất cả sản phẩm
                    </a>
                    @if (categories != null)
                    {
                        foreach (var cat in categories)
                        {
                            <a href="/Shop?categoryId=@cat.Id" class="category-link @(selectedId == cat.Id ? "active" : "")">
                                <i class="fa @cat.Icon"></i> @cat.Name
                            </a>
                        }
                    }
                </div>
            </div>
        </aside>

        <!-- Product Grid -->
        <main>
            @if (!Model.Any())
            {
                <div class="card-vn" style="padding: 60px; text-align: center;">
                    <img src="https://cdni.iconscout.com/illustration/premium/thumb/empty-cart-2130356-1800917.png" style="width: 200px; opacity: 0.5; margin-bottom: 20px;" />
                    <h3 style="color: var(--text-medium);">Không tìm thấy sản phẩm nào trong mục này.</h3>
                    <a href="/Shop" style="color: var(--primary); font-weight: 600; text-decoration: none; margin-top: 12px; display: inline-block;">Quay lại cửa hàng</a>
                </div>
            }
            else
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px;">
                    @foreach (var item in Model)
                    {
                        <div class="product-card">
                            <a href="/Product/Detail/@item.Id" style="text-decoration: none; color: inherit;">
                                <div class="product-img-wrapper">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)" alt="@item.Name" />
                                    @if (item.StockQuantity <= 0)
                                    {
                                        <div class="out-of-stock-label">Hết hàng</div>
                                    }
                                </div>
                                <div style="padding: 16px;">
                                    <div style="font-size: 12px; color: var(--primary); font-weight: 700; margin-bottom: 4px; text-transform: uppercase;">
                                        @item.Category.Name
                                    </div>
                                    <h3 class="product-title" title="@item.Name">@item.Name</h3>
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px;">
                                        <div style="font-size: 18px; font-weight: 800; color: #ef4444;">
                                            @item.Price.ToString("N0") <span style="font-size: 14px;">đ</span>
                                        </div>
                                        <div style="font-size: 12px; color: var(--text-medium);">
                                            Kho: @item.StockQuantity
                                        </div>
                                    </div>
                                </div>
                            </a>
                            <div style="padding: 0 16px 16px;">
                                <form asp-controller="Cart" asp-action="AddProductToCart" method="post">
                                    <input type="hidden" name="productId" value="@item.Id" />
                                    <button type="submit" class="add-cart-btn" @(item.StockQuantity <= 0 ? "disabled" : "")>
                                        <i class="fa fa-cart-plus"></i> Thêm vào giỏ
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>

    </div>
</div>

<style>
    .category-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-radius: 8px;
        text-decoration: none;
        color: var(--text-dark);
        font-weight: 500;
        transition: all 0.2s;
        font-size: 14px;
    }
    .category-link:hover { background: #f1f5f9; color: var(--primary); }
    .category-link.active { background: #fffbef; color: var(--primary); font-weight: 700; }
    .category-link i { width: 16px; text-align: center; font-size: 16px; opacity: 0.7; }

    .product-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
        transition: all 0.3s;
        display: flex;
        flex-direction: column;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
        border-color: var(--primary-light);
    }

    .product-img-wrapper {
        position: relative;
        padding-top: 100%; /* 1:1 Aspect Ratio */
        overflow: hidden;
        background: #f8fafc;
    }
    .product-img-wrapper img {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        object-fit: cover;
    }

    .out-of-stock-label {
        position: absolute;
        top: 10px; right: 10px;
        background: rgba(0,0,0,0.7);
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
    }

    .product-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--text-dark);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
        height: 42px;
    }

    .add-cart-btn {
        width: 100%;
        padding: 10px;
        border: 1px solid var(--primary);
        background: transparent;
        color: var(--primary);
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .add-cart-btn:hover:not(:disabled) { background: var(--primary); color: white; }
    .add-cart-btn:disabled { border-color: #e2e8f0; color: #94a3b8; cursor: not-allowed; }
</style>
