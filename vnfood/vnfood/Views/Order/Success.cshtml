@model vnfood.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div style="max-width: 800px; margin: 0 auto; padding-top: 60px; text-align:center;">
    <div style="width:100px; height:100px; background:#f0fdf4; color:#22c55e; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 30px; font-size:48px; border:4px solid #bbf7d0;">
        <i class="fa fa-check-circle"></i>
    </div>
    
    <h1 style="font-size:32px; font-weight:800; color:var(--text-dark); margin-bottom:16px;">ĐẶT HÀNG THÀNH CÔNG!</h1>
    <p style="font-size:16px; color:var(--text-medium); margin-bottom:40px;">Cảm ơn bạn đã tin tưởng và sử dụng dịch vụ của Bếp Việt. Mã đơn hàng của bạn là: <strong style="color:var(--primary);">#ORD-@Model.Id</strong></p>

    <div class="card-vn" style="padding:32px; text-align:left; margin-bottom:40px;">
        <h3 style="font-size:18px; font-weight:700; margin-bottom:20px; color:var(--text-dark); border-bottom:1px solid var(--border); padding-bottom:12px;">CHI TIẾT ĐƠN HÀNG</h3>
        
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:24px; margin-bottom:30px;">
            <div>
                <div style="font-size:13px; color:var(--text-medium); margin-bottom:6px; font-weight:600;">NGƯỜI NHẬN</div>
                <div style="font-size:15px; font-weight:700; color:var(--text-dark);">@Model.FullName</div>
                <div style="font-size:14px; color:var(--text-medium); margin-top:4px;">@Model.PhoneNumber</div>
            </div>
            <div>
                <div style="font-size:13px; color:var(--text-medium); margin-bottom:6px; font-weight:600;">ĐỊA CHỈ GIAO HÀNG</div>
                <div style="font-size:14px; color:var(--text-dark); line-height:1.5;">@Model.Address</div>
            </div>
        </div>

        <div style="background:#f8fafc; border-radius:12px; padding:20px;">
            @foreach (var item in Model.OrderItems)
            {
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                    <div style="display:flex; align-items:center; gap:12px;">
                        <span style="font-size:14px; font-weight:600; color:var(--text-dark); width:24px;">x @item.Quantity</span>
                        <span style="font-size:14px; color:var(--text-dark);">@(item.Post?.Title ?? item.Product?.Name)</span>
                    </div>
                    <span style="font-size:14px; font-weight:700; color:var(--text-dark);">@((item.UnitPrice * item.Quantity).ToString("N0")) đ</span>
                </div>
            }
            <hr style="border:none; border-top:1px solid var(--border); margin:16px 0;" />
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <span style="font-weight:700; font-size:16px;">TỔNG CỘNG</span>
                <span style="font-weight:800; font-size:22px; color:var(--primary);">@Model.TotalAmount.ToString("N0") đ</span>
            </div>
        </div>
    </div>

    <div style="display:flex; gap:16px; justify-content:center;">
        <a href="/" class="btn-primary-vn" style="background:#f1f5f9; color:var(--text-dark); border:1px solid #e2e8f0; text-decoration:none; padding:12px 30px; border-radius:12px; font-weight:700;">VỀ TRANG CHỦ</a>
        <a href="/Order" class="btn-primary-vn" style="background:var(--primary); color:#fff; text-decoration:none; padding:12px 30px; border-radius:12px; font-weight:700;">THEO DÕI ĐƠN HÀNG</a>
    </div>
</div>
