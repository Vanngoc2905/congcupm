@model vnfood.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<div style="max-width: 1000px; margin: 0 auto; padding-top: 30px;">
    <h1 style="font-size:24px; font-weight:800; margin-bottom:24px; color:var(--text-dark);">
        <i class="fa fa-credit-card" style="color:var(--primary);"></i> Thông tin thanh toán
    </h1>

    <div style="display:grid; grid-template-columns: 1fr 380px; gap:24px; align-items: start;">
        <div class="card-vn" style="padding:32px;">
            <h3 style="font-size:18px; font-weight:700; margin-bottom:24px; color:var(--text-dark); border-bottom:1px solid var(--border); padding-bottom:12px;">ĐỊA CHỈ GIAO HÀNG</h3>
            <form asp-action="PlaceOrder" asp-controller="Order" method="post" id="checkoutForm">
                <div style="margin-bottom:20px;">
                    <label asp-for="FullName" style="display:block; font-weight:600; margin-bottom:8px; font-size:14px; color:var(--text-medium);">HỌ TÊN NGƯỜI NHẬN</label>
                    <input asp-for="FullName" style="width:100%; padding:12px; border:1px solid var(--border); border-radius:8px; font-size:15px; background:#f8fafc;" placeholder="Nhập tên người nhận..." />
                    <span asp-validation-for="FullName" style="color:#ef4444; font-size:12px; margin-top:4px; display:block;"></span>
                </div>
                
                <div style="margin-bottom:20px;">
                    <label asp-for="PhoneNumber" style="display:block; font-weight:600; margin-bottom:8px; font-size:14px; color:var(--text-medium);">SỐ ĐIỆN THOẠI</label>
                    <input asp-for="PhoneNumber" style="width:100%; padding:12px; border:1px solid var(--border); border-radius:8px; font-size:15px; background:#f8fafc;" placeholder="Số điện thoại liên hệ..." />
                    <span asp-validation-for="PhoneNumber" style="color:#ef4444; font-size:12px; margin-top:4px; display:block;"></span>
                </div>
                
                <div style="margin-bottom:30px;">
                    <label asp-for="Address" style="display:block; font-weight:600; margin-bottom:8px; font-size:14px; color:var(--text-medium);">ĐỊA CHỈ CHI TIẾT</label>
                    <textarea asp-for="Address" rows="3" style="width:100%; padding:12px; border:1px solid var(--border); border-radius:8px; font-size:15px; background:#f8fafc; font-family:inherit; resize:none;" placeholder="Số nhà, tên đường, phường/xã, quận/huyện..."></textarea>
                    <span asp-validation-for="Address" style="color:#ef4444; font-size:12px; margin-top:4px; display:block;"></span>
                </div>

                <div style="margin-bottom:30px;">
                    <label style="display:block; font-weight:600; margin-bottom:12px; font-size:14px; color:var(--text-medium);"><i class="fa fa-credit-card"></i> PHƯƠNG THỨC THANH TOÁN</label>
                    
                    <div class="payment-method-options" style="display:grid; gap:12px;">
                        <label class="payment-option @(Model.PaymentMethod == "COD" ? "active" : "")">
                            <input type="radio" asp-for="PaymentMethod" value="COD" checked onclick="this.closest('.payment-method-options').querySelectorAll('.payment-option').forEach(el=>el.classList.remove('active')); this.parentElement.classList.add('active');" />
                            <div class="payment-icon"><i class="fa fa-truck-fast"></i></div>
                            <div class="payment-info">
                                <div class="payment-name">Thanh toán khi nhận hàng (COD)</div>
                                <div class="payment-desc">Kiểm tra hàng trước khi thanh toán</div>
                            </div>
                        </label>

                        <label class="payment-option @(Model.PaymentMethod == "Bank" ? "active" : "")">
                            <input type="radio" asp-for="PaymentMethod" value="Bank" onclick="this.closest('.payment-method-options').querySelectorAll('.payment-option').forEach(el=>el.classList.remove('active')); this.parentElement.classList.add('active');" />
                            <div class="payment-icon"><i class="fa fa-university"></i></div>
                            <div class="payment-info">
                                <div class="payment-name">Chuyển khoản Ngân hàng / QR</div>
                                <div class="payment-desc">Xác nhận đơn hàng nhanh hơn</div>
                            </div>
                        </label>
                    </div>
                </div>

                <style>
                    .payment-option {
                        display: flex;
                        gap: 16px;
                        padding: 16px;
                        border: 2px solid #e2e8f0;
                        border-radius: 12px;
                        cursor: pointer;
                        transition: all 0.2s;
                        align-items: center;
                        position: relative;
                    }
                    .payment-option:hover { background: #f8fafc; border-color: #cbd5e1; }
                    .payment-option.active { border-color: var(--primary); background: #fffbef; }
                    .payment-option input { 
                        position: absolute;
                        opacity: 0;
                        cursor: pointer;
                    }
                    .payment-icon {
                        width: 40px;
                        height: 40px;
                        background: #f1f5f9;
                        border-radius: 10px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 20px;
                        color: #475569;
                    }
                    .payment-option.active .payment-icon { background: var(--primary); color: white; }
                    .payment-name { font-weight: 700; color: var(--text-dark); size: 15px; }
                    .payment-desc { font-size: 12px; color: var(--text-medium); margin-top: 2px; }
                </style>

                <button type="submit" class="btn-primary-vn" style="width:100%; background:var(--primary); color:#fff; border:none; padding:15px; font-size:16px; font-weight:800; border-radius:8px; cursor:pointer; box-shadow:0 10px 15px -3px rgba(0,0,0,0.1);">HOÀN TẤT ĐẶT HÀNG</button>
            </form>
        </div>

        <div>
            <div class="card-vn" style="padding:24px; position:sticky; top:30px;">
                <h3 style="font-size:16px; font-weight:700; margin-bottom:20px; color:var(--text-dark);">Tóm tắt đơn hàng</h3>
                <div style="max-height:300px; overflow-y:auto; margin-bottom:24px; padding-right:8px;">
                    @foreach (var item in Model.CartItems)
                    {
                        var name = item.Post?.Title ?? item.Product?.Name;
                        var img = item.Post?.ImageUrl ?? item.Product?.ImageUrl;
                        var price = item.Post != null ? (item.Post.Price ?? 0) : item.Product.Price;

                        <div style="display:flex; gap:12px; margin-bottom:16px; align-items:center;">
                            <div style="width:45px; height:45px; border-radius:6px; overflow:hidden; background:#f1f5f9; flex-shrink:0; position:relative;">
                                @if (!string.IsNullOrEmpty(img))
                                { <img src="@img" style="width:100%; height:100%; object-fit:cover;" /> }
                                <div style="position:absolute; top:-5px; right:-5px; width:18px; height:18px; background:var(--primary); color:#fff; border-radius:50%; font-size:10px; display:flex; align-items:center; justify-content:center; border:2px solid #fff;">@item.Quantity</div>
                            </div>
                            <div style="flex:1;">
                                <div style="font-size:13.5px; font-weight:600; color:var(--text-dark); margin-bottom:2px; display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;">@name</div>
                                <div style="font-size:12px; color:var(--text-medium);">@price.ToString("N0") đ</div>
                            </div>
                            <div style="font-size:14px; font-weight:700; color:var(--text-dark);">@((price * item.Quantity).ToString("N0")) đ</div>
                        </div>
                    }
                </div>
                <hr style="border:none; border-top:1px solid var(--border); margin-bottom:20px;" />
                <div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:14px;">
                    <span style="color:var(--text-medium);">Tạm tính</span>
                    <span style="font-weight:600;">@Model.TotalAmount.ToString("N0") đ</span>
                </div>
                <div style="display:flex; justify-content:space-between; margin-bottom:20px; font-size:14px;">
                    <span style="color:var(--text-medium);">Giao hàng</span>
                    <span style="color:#22c55e; font-weight:600;">Miễn phí</span>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span style="font-weight:700; font-size:16px;">TỔNG CỘNG</span>
                    <span style="font-weight:800; font-size:22px; color:var(--primary);">@Model.TotalAmount.ToString("N0") đ</span>
                </div>
            </div>
            
            <a href="/Cart" style="display:block; text-align:center; padding:16px; color:var(--text-medium); font-size:14px; text-decoration:none; font-weight:500;"><i class="fa fa-arrow-left" style="margin-right:8px;"></i> Quay lại giỏ hàng</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
