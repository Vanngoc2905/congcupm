@model vnfood.ViewModels.EditProfileViewModel
@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
    ViewData["ActiveNav"] = "profile";
}

<div class="content-center">
    <div class="card-vn" style="padding: 28px;">
        <h2 style="font-size:20px; font-weight:700; margin-bottom:24px; color:var(--text-dark);">
            <i class="fa fa-user-pen" style="color:var(--primary);"></i> Chỉnh sửa hồ sơ
        </h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert-vn success"><i class="fa fa-check-circle"></i> @TempData["Success"]</div>
        }

        <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Avatar upload -->
            @{
                var currentAvatarUrl = ViewBag.CurrentAvatarUrl as string;
            }
            <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px; padding-bottom:20px; border-bottom:1px solid var(--border);">
                <div id="avatar-preview" class="profile-avatar" style="width:80px; height:80px; font-size:28px; flex-shrink:0;">
                    @if (!string.IsNullOrEmpty(currentAvatarUrl))
                    {
                        <img src="@currentAvatarUrl" id="avatar-img" alt="Avatar" />
                    }
                    else
                    {
                        <span id="avatar-text">@(Model.FullName?.FirstOrDefault().ToString()?.ToUpper() ?? "?")</span>
                    }
                </div>
                <div>
                    <label for="AvatarFile" id="edit-profile-avatar-label" style="background:var(--primary); color:#fff; padding:9px 20px; border-radius:8px; cursor:pointer; font-size:13.5px; font-weight:600; display:inline-block;">
                        <i class="fa fa-camera"></i> Đổi ảnh đại diện
                    </label>
                    <input type="file" name="AvatarFile" id="AvatarFile" accept="image/*" style="display:none;" />
                    <div style="font-size:12px; color:var(--text-light); margin-top:8px;">JPG, PNG, GIF, WEBP — Tối đa 5MB</div>
                </div>
            </div>

            <div class="form-group-vn">
                <label asp-for="FullName">Họ và tên</label>
                <input asp-for="FullName" type="text" placeholder="Nhập họ và tên" id="edit-fullname" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group-vn">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" readonly style="background:var(--bg-main); cursor:not-allowed;" />
                <span style="font-size:11.5px; color:var(--text-light); margin-top:4px; display:block;">Email không thể thay đổi</span>
            </div>

            <div class="form-group-vn">
                <label asp-for="Bio">Tiểu sử</label>
                <textarea name="Bio" id="edit-bio" rows="3" placeholder="Giới thiệu bản thân, sở thích ẩm thực..." 
                          style="width:100%; padding:11px 16px; border:1.5px solid var(--border); border-radius:8px; font-size:14px; font-family:inherit; color:var(--text-dark); resize:vertical; outline:none; transition:all 0.25s;"
                          maxlength="250">@Model.Bio</textarea>
                <div style="text-align:right; font-size:11.5px; color:var(--text-light); margin-top:4px;" id="bio-count">0/250</div>
            </div>

            <div style="margin-bottom: 24px;">
                <a href="/Account/ChangePassword" style="text-decoration:none; color:var(--primary); font-size:14px; font-weight:600;">
                    <i class="fa fa-lock"></i> Đổi mật khẩu?
                </a>
            </div>

            <div style="display:flex; gap:12px; margin-top:8px;">
                <button type="submit" class="btn-primary-vn" style="flex:1;" id="save-profile-btn">
                    <i class="fa fa-save"></i> Lưu thay đổi
                </button>
                <a href="/Account/Profile" class="btn-edit-profile" style="padding:12px 22px;" id="cancel-edit-btn">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Avatar preview
        document.getElementById('AvatarFile').addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (ev) {
                const preview = document.getElementById('avatar-preview');
                preview.innerHTML = '<img src="' + ev.target.result + '" id="avatar-img" alt="Avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />';
            };
            reader.readAsDataURL(file);
        });

        // Bio counter
        const bioEl = document.getElementById('edit-bio');
        const bioCount = document.getElementById('bio-count');
        if (bioEl) {
            const update = () => { bioCount.textContent = bioEl.value.length + '/250'; };
            update();
            bioEl.addEventListener('input', update);
        }

        // Focus style for textarea
        bioEl?.addEventListener('focus', () => bioEl.style.borderColor = '#F5A623');
        bioEl?.addEventListener('blur', () => bioEl.style.borderColor = '#E8EAF0');
    </script>
}
