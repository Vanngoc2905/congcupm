@model vnfood.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ActiveNav"] = "profile";
}

<div class="content-center">
    <div class="card-vn" style="padding: 28px;">
        <h2 style="font-size:20px; font-weight:700; margin-bottom:24px; color:var(--text-dark);">
            <i class="fa fa-key" style="color:var(--primary);"></i> Đổi mật khẩu
        </h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert-vn success"><i class="fa fa-check-circle"></i> @TempData["Success"]</div>
        }

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:16px; font-size:14px;"></div>

            <div class="form-group-vn">
                <label asp-for="OldPassword">Mật khẩu hiện tại</label>
                <input asp-for="OldPassword" type="password" placeholder="Nhập mật khẩu hiện tại" />
                <span asp-validation-for="OldPassword" class="text-danger"></span>
            </div>

            <div class="form-group-vn">
                <label asp-for="NewPassword">Mật khẩu mới</label>
                <input asp-for="NewPassword" type="password" placeholder="Nhập mật khẩu mới" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="form-group-vn">
                <label asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                <input asp-for="ConfirmPassword" type="password" placeholder="Xác nhận mật khẩu mới" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div style="display:flex; gap:12px; margin-top:16px;">
                <button type="submit" class="btn-primary-vn" style="flex:1;">
                    <i class="fa fa-check"></i> Xác nhận đổi mật khẩu
                </button>
                <a href="/Account/EditProfile" class="btn-edit-profile" style="padding:12px 22px; text-decoration:none;">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
