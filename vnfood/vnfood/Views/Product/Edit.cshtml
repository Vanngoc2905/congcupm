@model vnfood.Models.Product
@{
    ViewData["Title"] = "Chỉnh sửa Sản phẩm - Bếp Việt";
}

<div style="max-width: 800px; margin: 0 auto; padding-top: 20px;">
    
    <div class="card-vn" style="padding: 30px;">
        <h2 style="font-size: 24px; font-weight: 800; margin-bottom: 24px; color: var(--text-dark); display: flex; align-items: center; gap: 12px;">
            <i class="fa fa-pen-to-square" style="color: var(--primary);"></i> Chỉnh sửa Sản phẩm
        </h2>

        <form asp-controller="Product" asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-group-vn">
                <label asp-for="Name">TÊN SẢN PHẨM</label>
                <input asp-for="Name" class="form-control-vn" required />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1.5fr; gap: 20px; margin-top: 20px;">
                <div class="form-group-vn">
                    <label asp-for="Price">GIÁ BÁN (VNĐ)</label>
                    <input asp-for="Price" type="number" class="form-control-vn" required />
                </div>
                
                <div class="form-group-vn">
                    <label asp-for="StockQuantity">SỐ LƯỢNG KHO</label>
                    <input asp-for="StockQuantity" type="number" class="form-control-vn" required />
                </div>

                <div class="form-group-vn">
                    <label asp-for="CategoryId">DANH MỤC</label>
                    <select asp-for="CategoryId" class="form-control-vn" required>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in (List<vnfood.Models.Category>)ViewBag.Categories)
                            {
                                <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="form-group-vn" style="margin-top: 20px;">
                <label asp-for="Description">MÔ TẢ NGẮN / CHI TIẾT</label>
                <textarea asp-for="Description" class="form-control-vn" rows="5"></textarea>
            </div>

            <div style="display: flex; justify-content: flex-end; gap: 16px; margin-top: 40px;">
                <a href="/Vendor/MyProducts" class="btn-primary-vn" style="background: #f1f5f9; color: #475569; text-decoration: none;">Hủy</a>
                <button type="submit" class="btn-primary-vn" style="padding-left: 40px; padding-right: 40px;">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>
