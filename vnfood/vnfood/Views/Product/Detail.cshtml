@model vnfood.Models.Product
@{
    ViewData["Title"] = Model.Name + " - Bếp Việt Shop";
    bool isOutOfStock = Model.StockQuantity <= 0;
}

<div style="max-width: 1000px; margin: 0 auto; padding: 24px 16px;">
    
    <nav style="margin-bottom: 20px; font-size: 14px; color: var(--text-medium);">
        <a href="/" style="text-decoration:none; color:inherit;">Trang chủ</a> / 
        <a href="/Shop" style="text-decoration:none; color:inherit;">Chợ Bếp Việt</a> / 
        <span style="color:var(--text-dark); font-weight:600;">@Model.Name</span>
    </nav>

    <div class="card-vn" style="padding: 30px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">
        
        <!-- Left: Images -->
        <div>
            <div style="border-radius: 12px; overflow: hidden; border: 1px solid var(--border); background: #f8fafc; position: relative; padding-top: 100%;">
                <img src="@(Model.ImageUrl ?? "/images/no-image.png")" style="position: absolute; top:0; left:0; width:100%; height:100%; object-fit: contain;" />
            </div>
            
            <div style="display: flex; gap: 12px; margin-top: 12px;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl2))
                {
                    <div style="width: 80px; height: 80px; border-radius: 8px; border: 1px solid var(--border); overflow: hidden; cursor: pointer;">
                        <img src="@Model.ImageUrl2" style="width:100%; height:100%; object-fit: cover;" onclick="this.closest('.card-vn').querySelector('img').src=this.src" />
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.ImageUrl3))
                {
                    <div style="width: 80px; height: 80px; border-radius: 8px; border: 1px solid var(--border); overflow: hidden; cursor: pointer;">
                        <img src="@Model.ImageUrl3" style="width:100%; height:100%; object-fit: cover;" onclick="this.closest('.card-vn').querySelector('img').src=this.src" />
                    </div>
                }
            </div>
        </div>

        <!-- Right: Content -->
        <div style="display: flex; flex-direction: column;">
            <div style="font-size: 13px; color: var(--primary); font-weight: 700; text-transform: uppercase; margin-bottom: 8px;">
                @Model.Category.Name
            </div>
            <h1 style="font-size: 32px; font-weight: 800; color: var(--text-dark); margin-bottom: 16px; line-height: 1.2;">
                @Model.Name
            </h1>

            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
                <div style="font-size: 36px; font-weight: 900; color: #ef4444;">
                    @Model.Price.ToString("N0") <span style="font-size: 18px;">đ</span>
                </div>
                @if (isOutOfStock)
                {
                    <span style="background: #fee2e2; color: #991b1b; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 700;">Hết hàng</span>
                }
                else
                {
                    <span style="background: #dcfce7; color: #166534; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 700;">Còn hàng: @Model.StockQuantity</span>
                }
            </div>

            <div style="background: #f8fafc; border-radius: 12px; padding: 20px; margin-bottom: 30px;">
                <h4 style="font-size: 14px; font-weight: 700; color: var(--text-medium); margin-bottom: 12px; text-transform: uppercase;">Thông tin người bán</h4>
                <div style="display: flex; align-items: center; gap: 12px;">
                    <img src="@(Model.User.AvatarUrl ?? "/images/default-avatar.png")" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                    <div>
                        <div style="font-weight: 700; color: var(--text-dark);">@Model.User.FullName</div>
                        <div style="font-size: 12px; color: var(--text-medium);">Tham gia từ: @Model.User.Id.Substring(0, 8)</div>
                    </div>
                </div>
            </div>

            <div style="margin-top: auto; display: grid; grid-template-columns: 1fr; gap: 16px;">
                @if (!isOutOfStock)
                {
                    <form asp-controller="Cart" asp-action="AddProductToCart" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <button type="submit" class="btn-primary-vn" style="width:100%; height: 56px; border: none; font-size: 18px; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 12px; box-shadow: 0 4px 12px rgba(234, 179, 8, 0.3);">
                            <i class="fa fa-cart-plus"></i> THÊM VÀO GIỎ HÀNG
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn-primary-vn" disabled style="width:100%; height: 56px; background: #e2e8f0; color: #94a3b8; border: none; font-size: 18px; font-weight: 800; cursor: not-allowed;">
                        TẠM HẾT HÀNG
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Bottom: Description -->
    <div class="card-vn" style="margin-top: 30px; padding: 30px;">
        <h3 style="font-size: 20px; font-weight: 800; margin-bottom: 20px; border-bottom: 2px solid var(--primary); display: inline-block; padding-bottom: 8px;">Mô tả sản phẩm</h3>
        <div style="color: var(--text-dark); line-height: 1.8; font-size: 16px; white-space: pre-line;">
            @Model.Description
        </div>
    </div>

</div>
