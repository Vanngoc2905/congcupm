@using vnfood.Models
@using vnfood.ViewModels
@model MessagesViewModel
@{
    ViewData["Title"] = "Tin nhắn";
    ViewData["ActiveNav"] = "messages";
    var currentUser = ViewBag.CurrentUser as ApplicationUser;
}

<style>
    .main-content { padding: 0; }
</style>

<div class="messages-layout">
    <div class="messages-sidebar">
        <div style="padding:16px 16px 10px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between;">
            <h2 style="font-size:17px; font-weight:700; color:var(--text-dark);">Tin nhắn</h2>
        </div>

        <div class="conversation-list">
            @if (Model.Contacts.Count == 0)
            {
                <div style="padding:40px 20px; text-align:center;">
                    <i class="fa fa-users" style="font-size:32px; color:#D1D5DB; margin-bottom:12px;"></i>
                    <div style="color:var(--text-medium); font-size:14px; margin-bottom:16px;">Bạn chưa từng trò chuyện với ai.</div>
                    <a href="/Search?q=" class="btn-primary-vn" style="font-size:13px; text-decoration:none; display:inline-block; padding:8px 16px;">Tìm bạn bè</a>
                </div>
            }
            @foreach (var c in Model.Contacts)
            {
                var isActive = Model.ActiveContact?.Id == c.Id;
                <a href="/Messages?userId=@c.Id" class="conversation-item @(isActive ? "active" : "")" style="text-decoration:none; display:flex;">
                    <div class="conv-avatar" style="overflow:hidden;">
                        @if(!string.IsNullOrEmpty(c.AvatarUrl)) { <img src="@c.AvatarUrl" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" /> }
                        else { @(c.FullName?.FirstOrDefault().ToString()?.ToUpper() ?? c.UserName?.FirstOrDefault().ToString()?.ToUpper() ?? "?") }
                    </div>
                    <div class="conv-info">
                        <div class="conv-name" style="color:var(--text-dark);">@(c.FullName ?? c.UserName)</div>
                    </div>
                </a>
            }
        </div>
    </div>

    <div class="chat-panel" id="chat-panel">
        @if (Model.ActiveContact != null)
        {
            <div class="chat-header">
                <div class="conv-avatar" id="chat-header-avatar" style="overflow:hidden;">
                        @if(!string.IsNullOrEmpty(Model.ActiveContact.AvatarUrl)) { <img src="@Model.ActiveContact.AvatarUrl" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" /> }
                        else { @(Model.ActiveContact.FullName?.FirstOrDefault().ToString()?.ToUpper() ?? Model.ActiveContact.UserName?.FirstOrDefault().ToString()?.ToUpper() ?? "?") }
                </div>
                <div>
                    <div style="font-weight:700; font-size:15px;" id="chat-header-name">@(Model.ActiveContact.FullName ?? Model.ActiveContact.UserName)</div>
                </div>
            </div>

            <div class="chat-messages" id="chat-messages">
                @foreach(var msg in Model.Conversation)
                {
                    var isMine = msg.SenderId == currentUser?.Id;
                    <div class="chat-bubble-wrap @(isMine ? "mine" : "")">
                        @if (!isMine)
                        {
                            <div class="conv-avatar" style="width:30px; height:30px; font-size:14px; flex-shrink:0; overflow:hidden;">
                                @if(!string.IsNullOrEmpty(Model.ActiveContact.AvatarUrl)) { <img src="@Model.ActiveContact.AvatarUrl" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" /> }
                                else { @(Model.ActiveContact.FullName?.FirstOrDefault().ToString()?.ToUpper() ?? Model.ActiveContact.UserName?.FirstOrDefault().ToString()?.ToUpper() ?? "?") }
                            </div>
                        }
                        <div class="chat-bubble @(isMine ? "mine" : "theirs")" title="@msg.SentAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")">
                            @msg.Content
                        </div>
                    </div>
                }
            </div>

            <form action="/Messages/SendMessage" method="post" class="chat-input-bar">
                @Html.AntiForgeryToken()
                <input type="hidden" name="receiverId" value="@Model.ActiveContact.Id" />
                <input type="text" name="content" placeholder="Nhập tin nhắn..." id="msg-input" autocomplete="off" required style="border:none; outline:none; font-family:inherit; flex:1;" />
                <button type="submit" class="chat-send-btn" id="send-msg-btn">
                    <i class="fa fa-paper-plane"></i>
                </button>
            </form>
        }
        else
        {
            <div style="display:flex; align-items:center; justify-content:center; height:100%; color:var(--text-medium); flex-direction:column; padding:20px; text-align:center;">
                <i class="fa-regular fa-comments" style="font-size:48px; margin-bottom:16px; color:#D1D5DB;"></i>
                <p style="margin-bottom:20px; font-size:16px;">Chọn một cuộc trò chuyện từ danh sách, hoặc tìm kiếm người bạn mới để bắt đầu nhắn tin.</p>
                <a href="/Search?q=" class="btn-primary-vn" style="text-decoration:none; padding:10px 24px; font-weight:600; border-radius:24px;"><i class="fa fa-users"></i> Kết bạn bốn phương</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const container = document.getElementById('chat-messages');
            if (container) {
                container.scrollTop = container.scrollHeight;
            }
            document.getElementById('msg-input')?.focus();
        });
    </script>
}
